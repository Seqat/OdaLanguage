// engine.oda — Class & RAII demo (from Oda spec)

class Engine {
    int _rpm
    string _port

    construct(string port) {
        _port = port
        _rpm = 0
        print("Connected to " + _port)
    }

    func rev_up() {
        _rpm = _rpm + 1000
    }

    destruct() {
        print("Closing port: " + _port)
    }
}

Engine v8 = Engine("COM3")
v8.rev_up()
