// Array Tests
int[3] static_arr = [1, 2, 3]
int[] dynamic_arr = [4, 5, 6]

print("Static arr[0]: " + static_arr[0])
print("Dynamic arr[1]: " + dynamic_arr[1])

static_arr[0] = 100
dynamic_arr[1] = 500

print("After mutation:")
print("Static arr[0]: " + static_arr[0])
print("Dynamic arr[1]: " + dynamic_arr[1])

// Input test
print("Please enter something:")
string user_input = input()
print("You entered: " + user_input)
